# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === OneSwap API ===
ONESWAP_API=https://api.oneswap.cc

# === Polling ===
POLL_SECONDS=30
REARM_SECONDS=900
REBOUND_WATCH_MINUTES=15
REBOUND_RECOVER_PCT=80

# === Pairs ===
POOL_CC_USDCX=68ba82e7
POOL_CC_CBTC=0157e735

# === CC/USDCx thresholds ===
CC_USDCX_LOW=0.10
CC_USDCX_HIGH=0.25
CC_USDCX_WHALE_PCT=2.0

# === CC/CBTC thresholds ===
CC_CBTC_LOW=0.0000015
CC_CBTC_HIGH=0.000005
CC_CBTC_WHALE_PCT=5.0

# === Quote presets (comma-separated amounts) ===
QUOTE_PRESETS_USDCX=50,100,200
QUOTE_PRESETS_CC=500,1000,2000
QUOTE_PRESETS_CBTC=0.001,0.005

# === Auth (REQUIRED for swap execution) ===
PRIVATE_KEY_HEX=your_64char_hex_seed
PUBLIC_KEY_HEX=your_64char_hex_pubkey
RECEIVER_PARTY=consolewallet-xxx::xxx
CANTON_BASE_URL=https://consolewallet.io

# === Swap settings ===
SLIPPAGE_TOLERANCE=0.05
SWAP_COOLDOWN_SEC=60
